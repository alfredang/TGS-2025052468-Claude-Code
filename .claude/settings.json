{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__playwright",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/validate-booking.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__playwright",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/booking-success-tts.sh"
          }
        ]
      }
    ]
  }
}
